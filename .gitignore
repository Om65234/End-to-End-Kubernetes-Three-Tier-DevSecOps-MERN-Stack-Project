# =============================================================
# .gitignore — MERN Stack + Docker + Kubernetes DevSecOps Project
# =============================================================

# ─────────────────────────────────────────
# 📦 Dependencies
# ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js

# ─────────────────────────────────────────
# 🔐 Environment & Secrets (NEVER commit)
# ─────────────────────────────────────────
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/

# ─────────────────────────────────────────
# 🏗️ Build & Compilation Output
# ─────────────────────────────────────────
build/
dist/
out/
.next/
.nuxt/
.cache/
*.tsbuildinfo
frontend/build/
backend/dist/

# ─────────────────────────────────────────
# 🧪 Testing & Coverage
# ─────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
jest_html_reporters-output/

# ─────────────────────────────────────────
# 📝 Logs
# ─────────────────────────────────────────
logs/
*.log
combined.log
error.log
access.log
npm-debug.log
yarn-debug.log

# ─────────────────────────────────────────
# 🐳 Docker
# ─────────────────────────────────────────
.docker/
docker-compose.override.yml
docker-compose.local.yml

# ─────────────────────────────────────────
# ☸️ Kubernetes & Helm
# ─────────────────────────────────────────
kubeconfig
kubeconfig.yaml
*.kubeconfig
k8s/secrets/
helm/charts/*.tgz
.helm/

# ─────────────────────────────────────────
# 🖥️ IDE & Editor Files
# ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ─────────────────────────────────────────
# 💻 OS-Specific Files
# ─────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encdata
Desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# Linux
*~
.fuse_hidden*
.Trash-*

# ─────────────────────────────────────────
# 🔬 Security Scanning Output
# ─────────────────────────────────────────
trivy-results/
snyk-results/
owasp-report/
dependency-check-report/
bandit-output/
*.sarif

# ─────────────────────────────────────────
# 🚀 CI/CD
# ─────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
ansible/*.retry

# ─────────────────────────────────────────
# 📊 Monitoring & Debug Artifacts
# ─────────────────────────────────────────
heap-*.heapsnapshot
*.cpuprofile
*.heapdump

# ─────────────────────────────────────────
# 📦 Package Manager Locks (keep one only)
# ─────────────────────────────────────────
# Uncomment the one you are NOT using:
# package-lock.json   # if using yarn
# yarn.lock           # if using npm

# Logs
logs/
*.log
